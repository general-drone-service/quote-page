# Quote Standalone — Environment Variables
# Copy to .env.local and fill in values

# Supabase (independent project for quote module)
QUOTE_SUPABASE_URL=https://your-project.supabase.co
QUOTE_SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Public URL of this quote app (LINE 錯誤訊息 / lookup API 用)
# NEXT_PUBLIC_QUOTE_APP_URL=https://quote.drone168.com

# 共享 CRM（鏡像 paid-ad quote 進 ad_leads；server-only）。未設則自動 no-op。
CRM_SUPABASE_URL=https://wowjbqafysobqnlpdtcg.supabase.co
CRM_SUPABASE_SERVICE_ROLE_KEY=

# LINE Messaging API（官方帳號 Webhook → /api/line/webhook）
# LINE_CHANNEL_ACCESS_TOKEN=
# LINE_CHANNEL_SECRET=

# Optional: Taiwan Central Weather Agency API key (improves thunder forecast)
# CWA_API_KEY=

# Google Maps Platform
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=  # restricted by HTTP referrer; inlined into client bundle
GOOGLE_MAPS_SERVER_KEY=               # restricted by IP/API; server-only (Distance Matrix, Places)
